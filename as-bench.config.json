{
  "$schema": "./as-bench.config.schema.json",
  "input": ["assembly/__benches__/**/*.ts"],
  "buildOptions": {
    "args": ["--transform", "json-as/transform"]
  },
  "settings": {
    "warmupTime": 250,
    "measurementTime": 500,
    "numResamples": 20000
  },
  "modes": {
    "full": {
      "settings": {
        "warmupTime": 3000,
        "measurementTime": 5000,
        "numResamples": 100000
      }
    },
    "wasmtime": {
      "runtime": "wasmtime"
    },
    "wasmer": {
      "runtime": "wasmer"
    },
    "wazero": {
      "runOptions": {
        "runtime": {
          "cmd": "wazero run <env:-env> <file>"
        }
      }
    },
    "deterministic": {
      "deterministic": true
    },
    "compare": {
      "runOptions": {
        "runtime": ["node", "wasmtime", "wasmer", { "cmd": "wazero run <env:-env> <file>", "name": "wazero" }]
      }
    }
  }
}
